{
  "name": "terminator",
  "version": "1.0.0",
  "description": "T-800 Audio System — retro MPC looper",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.main.json && concurrently -k -n VITE,TSC,ELECTRON -c cyan,yellow,red \"vite\" \"tsc -p tsconfig.main.json --watch --preserveWatchOutput\" \"wait-on http://localhost:5173 && nodemon --watch dist/main --watch dist/preload --delay 500ms --exec 'node scripts/run-electron.js dist/main/main.js'\"",
    "build": "vite build && tsc -p tsconfig.main.json",
    "start": "node scripts/run-electron.js dist/main/main.js",
    "pack": "npm run build && electron-builder"
  },
  "keywords": [],
  "author": "thewoodendeer",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/thewoodendeer/terminator.git"
  },
  "homepage": "https://github.com/thewoodendeer/terminator",
  "type": "commonjs",
  "dependencies": {
    "electron": "^41.3.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "soundtouchjs": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.14",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.terminator.audio",
    "productName": "Terminator",
    "files": [
      "dist/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}
